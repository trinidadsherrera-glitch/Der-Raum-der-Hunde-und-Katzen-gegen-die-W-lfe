<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gatos y Perros vs Lobos Marcianos</title>
    <style>
        body {
            margin: 0;
            background-color: #0b0b1a;
            color: #00ffcc;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }
        h1 { margin: 10px 0; font-size: 24px; text-shadow: 0 0 10px #00ffcc; }
        canvas {
            background: linear-gradient(to bottom, #000000, #1a0033);
            border: 3px solid #ff00ff;
            box-shadow: 0 0 20px #ff00ff;
            border-radius: 8px;
        }
        .controls { margin-top: 15px; background: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 5px; }
    </style>
</head>
<body>

    <h1>🐾 Gatos y Perros vs Lobos Marcianos 🐺</h1>
    <canvas id="spaceCanvas" width="700" height="550"></canvas>
    <div class="controls">
        🕹️ <b>Izquierda / Derecha</b> para moverte &nbsp;|&nbsp; 🚀 <b>Barra Espaciadora</b> para disparar
    </div>

<script>
    const canvas = document.getElementById("spaceCanvas");
    const ctx = canvas.getContext("2d");

    // Estados del juego
    let gameState = "playing"; // playing, win, gameover
    let score = 0;

    // Jugador (Gato y Perro)
    const player = {
        x: canvas.width / 2 - 30,
        y: canvas.height - 50,
        width: 60,
        height: 30,
        speed: 6,
        dx: 0
    };

    // Arrays para entidades
    let playerBullets = [];
    let wolfBullets = [];
    let wolves = [];

    // Configuración de enemigos
    const rows = 4;
    const cols = 9;
    let wolfSpeed = 1.5;
    let wolfDirection = 1;

    // Generar Lobos
    function initWolves() {
        for (let r = 0; r < rows; r++) {
            for (let c = 0; c < cols; c++) {
                wolves.push({
                    x: c * 60 + 40,
                    y: r * 50 + 40,
                    width: 30,
                    height: 30,
                    alive: true
                });
            }
        }
    }
    initWolves();

    // Controles de teclado
    document.addEventListener("keydown", (e) => {
        if (e.code === "ArrowLeft") player.dx = -player.speed;
        if (e.code === "ArrowRight") player.dx = player.speed;
        if (e.code === "Space" && gameState === "playing") {
            if (playerBullets.length < 3) { // Máximo 3 balas a la vez
                playerBullets.push({ x: player.x + 25, y: player.y, width: 6, height: 15 });
            }
        }
        // Reiniciar juego
        if (e.code === "Enter" && gameState !== "playing") {
            resetGame();
        }
    });

    document.addEventListener("keyup", (e) => {
        if (e.code === "ArrowLeft" || e.code === "ArrowRight") player.dx = 0;
    });

    function resetGame() {
        gameState = "playing";
        score = 0;
        player.x = canvas.width / 2 - 30;
        playerBullets = [];
        wolfBullets = [];
        wolves = [];
        wolfSpeed = 1.5;
        wolfDirection = 1;
        initWolves();
    }

    function update() {
        if (gameState !== "playing") return;

        // Mover jugador
        player.x += player.dx;
        if (player.x < 0) player.x = 0;
        if (player.x + player.width > canvas.width) player.x = canvas.width - player.width;

        // Mover balas del jugador
        for (let i = playerBullets.length - 1; i >= 0; i--) {
            playerBullets[i].y -= 8;
            if (playerBullets[i].y < 0) playerBullets.splice(i, 1);
        }

        // Lógica de Lobos
        let hitWall = false;
        let aliveWolves = 0;

        wolves.forEach(wolf => {
            if (wolf.alive) {
                aliveWolves++;
                wolf.x += wolfSpeed * wolfDirection;
                if (wolf.x <= 10 || wolf.x + wolf.width >= canvas.width - 10) {
                    hitWall = true;
                }
                
                // Lobos disparan aleatoriamente
                if (Math.random() < 0.001) {
                    wolfBullets.push({ x: wolf.x + 15, y: wolf.y + 30, width: 5, height: 12 });
                }
            }
        });

        // Cambio de dirección y bajada
        if (hitWall) {
            wolfDirection *= -1;
            wolves.forEach(wolf => {
                if (wolf.alive) wolf.y += 20;
            });
            wolfSpeed += 0.2; // Se vuelven más rápidos
        }

        // Victoria
        if (aliveWolves === 0) gameState = "win";

        // Mover balas de los lobos
        for (let i = wolfBullets.length - 1; i >= 0; i--) {
            wolfBullets[i].y += 5;
            // Colisión con el jugador
            if (wolfBullets[i].x < player.x + player.width &&
                wolfBullets[i].x + wolfBullets[i].width > player.x &&
                wolfBullets[i].y < player.y + player.height &&
                wolfBullets[i].y + wolfBullets[i].height > player.y) {
                gameState = "gameover";
            }
            if (wolfBullets[i].y > canvas.height) wolfBullets.splice(i, 1);
        }

        // Colisiones balas del jugador vs Lobos
        for (let i = playerBullets.length - 1; i >= 0; i--) {
            let bulletHit = false;
            for (let j = 0; j < wolves.length; j++) {
                let wolf = wolves[j];
                if (wolf.alive &&
                    playerBullets[i].x < wolf.x + wolf.width &&
                    playerBullets[i].x + playerBullets[i].width > wolf.x &&
                    playerBullets[i].y < wolf.y + wolf.height &&
                    playerBullets[i].y + playerBullets[i].height > wolf.y) {
                    
                    wolf.alive = false;
                    bulletHit = true;
                    score += 10;
                    break;
                }
            }
            if (bulletHit) playerBullets.splice(i, 1);
        }
        
        // Lobos tocan al jugador (invasión completada)
        wolves.forEach(wolf => {
            if (wolf.alive && wolf.y + wolf.height >= player.y) {
                gameState = "gameover";
            }
        });
    }

    function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        if (gameState === "playing") {
            // Estrellas de fondo (simuladas rápido)
            ctx.fillStyle = "white";
            for(let i=0; i<30; i++) {
                ctx.fillRect(Math.random() * canvas.width, Math.random() * canvas.height, 1, 1);
            }

            // Dibujar Puntuación
            ctx.fillStyle = "#00ffcc";
            ctx.font = "20px Courier New";
            ctx.fillText("Puntos: " + score, 10, 30);

            // Dibujar Jugador (Gato y Perro)
            ctx.font = "35px Arial";
            ctx.fillText("🐱🐶", player.x, player.y + 30);

            // Dibujar Lobos
            wolves.forEach(wolf => {
                if (wolf.alive) {
                    ctx.font = "30px Arial";
                    ctx.fillText("🐺", wolf.x, wolf.y + 25);
                }
            });

            // Dibujar Balas Jugador
            ctx.fillStyle = "#00ffff";
            playerBullets.forEach(b => {
                ctx.fillRect(b.x, b.y, b.width, b.height);
            });

            // Dibujar Balas Enemigos
            ctx.fillStyle = "#ff0055";
            wolfBullets.forEach(b => {
                ctx.fillRect(b.x, b.y, b.width, b.height);
            });
        } 
        else if (gameState === "gameover") {
            ctx.fillStyle = "red";
            ctx.font = "40px Arial";
            ctx.textAlign = "center";
            ctx.fillText("¡LOS LOBOS CONQUISTARON!", canvas.width / 2, canvas.height / 2 - 20);
            ctx.fillStyle = "white";
            ctx.font = "20px Arial";
            ctx.fillText("Puntuación final: " + score, canvas.width / 2, canvas.height / 2 + 20);
            ctx.fillText("Presiona ENTER para reiniciar", canvas.width / 2, canvas.height / 2 + 60);
            ctx.textAlign = "left";
        }
        else if (gameState === "win") {
            ctx.fillStyle = "lime";
            ctx.font = "40px Arial";
            ctx.textAlign = "center";
            ctx.fillText("¡GALAXIA SALVADA!", canvas.width / 2, canvas.height / 2 - 20);
            ctx.fillStyle = "white";
            ctx.font = "20px Arial";
            ctx.fillText("Puntuación perfecta: " + score, canvas.width / 2, canvas.height / 2 + 20);
            ctx.fillText("Presiona ENTER para jugar de nuevo", canvas.width / 2, canvas.height / 2 + 60);
            ctx.textAlign = "left";
        }

        update();
        requestAnimationFrame(draw);
    }

    draw(); // Iniciar loop
</script>
</body>
</html>